@using AppPerfumaria.Api.ReinoCompany
@using AppPerfumaria.Exceptions
@using AppPerfumaria.Models.Auth
@using AppPerfumaria.Models.Tables
@using SkiaSharp
@using System.Globalization
@using System.Text.Json

@inject ExceptionService ExceptionService
@inject IDialogService Dialog
@inject IJSRuntime JS
@inject ISnackbar Snack

<MudDialog>
    <DialogContent>
        @if (!string.IsNullOrEmpty(_imagemMontadaBase64))
        {
            <div>
                <MudIconButton Style="position:absolute;" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                               Icon="@Icons.Material.Filled.Share" @onclick="CompartilharImagem" />
                <MudImage Class="rounded-lg w-100" Src="@($"data:image/png;base64,{_imagemMontadaBase64}")" Alt="@_imagemMontadaBase64" />
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-2">
                <MudProgressCircular Indeterminate="true" Color="Color.Default" />
            </div>
        }
    </DialogContent>
    <DialogActions>

    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance? _mudDialog { get; set; }
    [Parameter]
    public Auth? _auth { get; set; }
    [Parameter]
    public Estoques? _estoque { get; set; }
    public ProdutosDivulgacoes? _produtoDivulgacao;
    private string _imagemMontadaBase64 = string.Empty;
    private string _caminhoImagemGerada = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await BuscarColunaProdutoDivulgacao();
        await MontarImagem();
        StateHasChanged();
    }

    private async Task BuscarColunaProdutoDivulgacao()
    {
        try
        {
            var reinoCompany = new ReinoCompany();
            var response = await reinoCompany.ProdutosDivulagacoesBuscarColuna(_auth!.token!, _estoque!.produtos_id, "img_padrao_2");

            if (response!.status)
            {
                _produtoDivulgacao = response!.data!;
            }
            else
            {
                if (!string.IsNullOrEmpty(response.message))
                {
                    Snack.Add(response.message, Severity.Warning);
                }
            }

            StateHasChanged();
        }
        catch (Exception e)
        {
            ExceptionService.HandleAsync(e, "Tivemos um problema ao tentar buscar a divulgação do produto!");
        }
    }

    private async Task MontarImagem()
    {
        try
        {
            // 1️⃣ Carregar imagens base
            using var stream = await FileSystem.OpenAppPackageFileAsync("wwwroot/img/divulgacoes/modelo_background_sem_fundo.png");
            using var msFundo = new MemoryStream();
            await stream.CopyToAsync(msFundo);
            using var fundoBitmap = SKBitmap.Decode(msFundo.ToArray());

            using var streamEtiqueta = await FileSystem.OpenAppPackageFileAsync("wwwroot/img/divulgacoes/etiqueta_preco.png");
            using var etiquetaBitmap = SKBitmap.Decode(streamEtiqueta);

            using var streamLogo = await FileSystem.OpenAppPackageFileAsync("wwwroot/img/divulgacoes/logo_aroma_suave.png");
            using var logoBitmap = SKBitmap.Decode(streamLogo);

            // 2️⃣ Carregar imagem do produto
            var produtoBase64 = _estoque?.produto?.img_1;

            if (!string.IsNullOrEmpty(_produtoDivulgacao.img_padrao_2))
            {
                produtoBase64 = _produtoDivulgacao.img_padrao_2;
            }

            if (string.IsNullOrEmpty(produtoBase64)) return;
            byte[] produtoBytes = Convert.FromBase64String(produtoBase64);
            using var produtoBitmap = SKBitmap.Decode(produtoBytes);

            // 3️⃣ Criar área de desenho
            using var surface = SKSurface.Create(new SKImageInfo(fundoBitmap.Width, fundoBitmap.Height));
            var canvas = surface.Canvas;
            canvas.Clear(SKColors.Transparent);

            // 🎯 AJUSTES DO PRODUTO
            float percentualLargura = 0.90f;
            float larguraDesejadaProduto = fundoBitmap.Width * percentualLargura;
            float escala = larguraDesejadaProduto / produtoBitmap.Width;
            float larguraFinalProduto = produtoBitmap.Width * escala;
            float alturaFinalProduto = produtoBitmap.Height * escala;
            float posX = (fundoBitmap.Width - larguraFinalProduto) / 2;
            float offsetVertical = 235;
            float posY = ((fundoBitmap.Height - alturaFinalProduto) / 2) - offsetVertical;

            // --- CAMADA 1: PRODUTO ---
            canvas.Save();
            canvas.RotateDegrees(-6.0f, posX + (larguraFinalProduto / 2), posY + (alturaFinalProduto / 2));
            canvas.DrawBitmap(produtoBitmap, new SKRect(posX, posY, posX + larguraFinalProduto, posY + alturaFinalProduto));
            canvas.Restore();

            // --- CAMADA 2: FUNDO/MOLDURA ---
            canvas.DrawBitmap(fundoBitmap, 0, 0);

            // 🏷️ CAMADA 3 - TÍTULO
            string textoTitulo = FormatarNomeProduto(_estoque!.produto!.nome);
            using var paintTexto = new SKPaint
            {
                Color = SKColors.Black,
                IsAntialias = true,
                TextSize = 50,
                Typeface = SKTypeface.FromFamilyName("Georgia", SKFontStyleWeight.Bold, SKFontStyleWidth.Normal, SKFontStyleSlant.Upright),
                TextAlign = SKTextAlign.Center
            };

            var linhas = new List<string>();
            var palavras = textoTitulo.Split(' ');
            var linhaAtual = "";
            foreach (var p in palavras)
            {
                var teste = string.IsNullOrEmpty(linhaAtual) ? p : $"{linhaAtual} {p}";
                if (paintTexto.MeasureText(teste) > fundoBitmap.Width * 0.80f) { linhas.Add(linhaAtual); linhaAtual = p; }
                else { linhaAtual = teste; }
            }
            linhas.Add(linhaAtual);

            var retangulos = new List<SKRect>();
            for (int i = 0; i < linhas.Count; i++)
            {
                float w = paintTexto.MeasureText(linhas[i]) + 50;
                float h = paintTexto.TextSize + 24;
                float y = 100 + (i * (h - 6));
                float x = (fundoBitmap.Width - w) / 2;
                retangulos.Add(new SKRect(x, y, x + w, y + h));
            }

            using var paintSombraDensa = new SKPaint
            {
                IsAntialias = true,
                ImageFilter = SKImageFilter.CreateDropShadow(0, 8, 12, 12, SKColors.Black.WithAlpha(130))
            };
            using var paintBranco = new SKPaint { Color = SKColors.White, IsAntialias = true };

            foreach (var rect in retangulos) canvas.DrawRoundRect(rect, 15, 15, paintSombraDensa);

            // --- 4️⃣ DESENHAR ETIQUETA COM PREÇO DINÂMICO ---
            canvas.Save();
            float escalaEtiqueta = 0.8f;
            float larguraEtiqueta = etiquetaBitmap.Width * escalaEtiqueta;
            float alturaEtiqueta = etiquetaBitmap.Height * escalaEtiqueta;
            float xEtiqueta = -100;
            float yEtiqueta = fundoBitmap.Height - alturaEtiqueta - 125;

            canvas.RotateDegrees(5.0f, xEtiqueta + (larguraEtiqueta / 2), yEtiqueta + (alturaEtiqueta / 2));
            var rectEtiqueta = new SKRect(xEtiqueta, yEtiqueta, xEtiqueta + larguraEtiqueta, yEtiqueta + alturaEtiqueta);
            canvas.DrawBitmap(etiquetaBitmap, rectEtiqueta, paintSombraDensa);

            var cultura = new System.Globalization.CultureInfo("pt-BR");
            using var paintPreco = new SKPaint
            {
                IsAntialias = true,
                Typeface = SKTypeface.FromFamilyName("Arial", SKFontStyleWeight.Bold, SKFontStyleWidth.Normal, SKFontStyleSlant.Upright)
            };

            float centroX = rectEtiqueta.MidX + 130;
            float inicioY = rectEtiqueta.Top + 400;

            canvas.Save();
            canvas.RotateDegrees(7.5f, centroX, inicioY);

            paintPreco.Color = SKColors.Black;
            paintPreco.TextSize = 45;
            paintPreco.TextAlign = SKTextAlign.Center;
            string precoOriginal = _estoque.preco_venda_original?.ToString("N2", cultura);
            string textoDe = $"De: {precoOriginal}";
            canvas.DrawText(textoDe, centroX, inicioY, paintPreco);

            float larguraTextoDe = paintPreco.MeasureText(textoDe);
            canvas.DrawLine(centroX - (larguraTextoDe / 2), inicioY - 12, centroX + (larguraTextoDe / 2), inicioY - 12,
                new SKPaint { Color = SKColors.Black, StrokeWidth = 3, IsAntialias = true });

            string valorPor = $"Por: {_estoque.preco_venda_desconto?.ToString("N2", cultura)}";
            string condicaoPor = _estoque.preco_venda_avista != null ? " (cartão)" : " (cartão ou à vista)";

            paintPreco.TextSize = 55;
            float larguraValorPor = paintPreco.MeasureText(valorPor);
            paintPreco.TextSize = 40;
            float larguraCondicaoPor = paintPreco.MeasureText(condicaoPor);
            float totalPorX = larguraValorPor + larguraCondicaoPor;
            float startXPor = centroX - (totalPorX / 2);

            paintPreco.Color = SKColors.DarkRed;
            paintPreco.TextSize = 55;
            paintPreco.TextAlign = SKTextAlign.Left;
            canvas.DrawText(valorPor, startXPor, inicioY + 60, paintPreco);

            paintPreco.Color = SKColors.Black;
            paintPreco.TextSize = 40;
            canvas.DrawText(condicaoPor, startXPor + larguraValorPor, inicioY + 60, paintPreco);

            if (_estoque.preco_venda_avista != null)
            {
                string valorAV = $"        {_estoque.preco_venda_avista?.ToString("N2", cultura)}";
                string condicaoAV = " (à vista)";
                paintPreco.TextSize = 55;
                float larguraValorAV = paintPreco.MeasureText(valorAV);
                paintPreco.TextSize = 40;
                float larguraCondicaoAV = paintPreco.MeasureText(condicaoAV);
                float totalAVX = larguraValorAV + larguraCondicaoAV;
                float startXAV = centroX - (totalAVX / 2);

                paintPreco.Color = SKColors.DarkRed;
                paintPreco.TextSize = 55;
                canvas.DrawText(valorAV, startXAV, inicioY + 120, paintPreco);

                paintPreco.Color = SKColors.Black;
                paintPreco.TextSize = 40;
                canvas.DrawText(condicaoAV, startXAV + larguraValorAV, inicioY + 120, paintPreco);
            }

            canvas.Restore();
            canvas.Restore();

            // --- CAMADA FINAL ---
            paintTexto.TextAlign = SKTextAlign.Center;
            foreach (var rect in retangulos) canvas.DrawRoundRect(rect, 15, 15, paintBranco);
            for (int i = 0; i < linhas.Count; i++)
            {
                canvas.DrawText(linhas[i], retangulos[i].MidX, retangulos[i].MidY + (paintTexto.TextSize / 2) - 4, paintTexto);
            }

            // ==============================================================================
            // 📸 LOGOMARCA E INSTAGRAM (SUBIDOS)
            // ==============================================================================
            float larguraLogo = fundoBitmap.Width * 0.35f;
            float escalaLogo = larguraLogo / logoBitmap.Width;
            float alturaLogo = logoBitmap.Height * escalaLogo;
            
            float posXLogo = fundoBitmap.Width - larguraLogo - 30;
            // Alterado de -60 para -120 para subir a logo
            float posYLogo = fundoBitmap.Height - alturaLogo - 120;

            canvas.DrawBitmap(logoBitmap, new SKRect(posXLogo, posYLogo, posXLogo + larguraLogo, posYLogo + alturaLogo), new SKPaint { IsAntialias = true });

            using var paintInstagram = new SKPaint
            {
                Color = SKColors.DarkRed,
                IsAntialias = true,
                TextSize = 45,
                Typeface = SKTypeface.FromFamilyName("Arial", SKFontStyleWeight.Bold, SKFontStyleWidth.Normal, SKFontStyleSlant.Upright),
                TextAlign = SKTextAlign.Center
            };

            float centroXLogo = posXLogo + (larguraLogo / 2);
            float posYInstagram = posYLogo + alturaLogo + 45; // Posicionado em relação à nova altura da logo
            canvas.DrawText("@_aromasuave_", centroXLogo, posYInstagram, paintInstagram);
            // ==============================================================================

            // 6️⃣ Finalização
            using var imagemFinal = surface.Snapshot();
            using var dados = imagemFinal.Encode(SKEncodedImageFormat.Png, 100);
            var caminho = Path.Combine(FileSystem.CacheDirectory, "oferta_produto.png");
            if (File.Exists(caminho)) File.Delete(caminho);
            using (var fileStream = File.OpenWrite(caminho)) dados.SaveTo(fileStream);

            _imagemMontadaBase64 = Convert.ToBase64String(dados.ToArray());
            _caminhoImagemGerada = caminho;
            StateHasChanged();
        }
        catch (Exception e)
        {
            Snack.Add("Tivemos um problema ao tentar gerar a imagem!", Severity.Warning);
        }
    }

    private string FormatarNomeProduto(string nome)
    {
        if (string.IsNullOrWhiteSpace(nome)) return string.Empty;

        // Lista de palavras que devem permanecer em minúsculo (conectivos)
        var excecoes = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "de", "do", "da", "dos", "das", "e", "com", "a", "o", "para", "em", "g", "ml", "kg"
    };

        // Divide o nome em palavras e remove espaços extras
        string[] palavras = nome.ToLower().Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);

        for (int i = 0; i < palavras.Length; i++)
        {
            // Regra: A primeira palavra SEMPRE começa com maiúscula.
            // As demais só começam com maiúscula se NÃO estiverem na lista de exceções.
            if (i == 0 || !excecoes.Contains(palavras[i]))
            {
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i].Substring(1);
            }
        }

        return string.Join(" ", palavras);
    }

    private async Task CompartilharImagem()
    {
        try
        {
            if (string.IsNullOrEmpty(_caminhoImagemGerada) || !File.Exists(_caminhoImagemGerada))
            {
                Snack.Add("Imagem ainda não foi gerada para compartilhamento.", Severity.Warning);
                return;
            }

            await Share.RequestAsync(new ShareFileRequest
            {
                Title = $"{_estoque!.produto!.nome}",
                File = new ShareFile(_caminhoImagemGerada)
            });
        }
        catch (Exception e)
        {
            Snack.Add("Tivemos um problema ao tentar compartilhar a imagem!", Severity.Warning);
        }
    }
}
